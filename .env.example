# ============================================================
#  ZD Birthdays — Environment Configuration (example)
# ------------------------------------------------------------
#  Copy this file to ".env" and fill in real values.
#  ".env" is git-ignored — never commit live credentials.
# ============================================================

# --- Database ---
DB_HOST=localhost
DB_NAME=zdbd
DB_USER=root
DB_PASS=

# --- Application ---
# development | production
APP_ENV=development
# URL sub-path the site is served from. Use "" if it lives at the web root.
APP_BASE=/ZD_Birthdays
APP_TIMEZONE=Africa/Lusaka

# --- Sessions & edit locks (seconds) ---
# How long an admin stays signed in without any request (8 hours).
SESSION_LIFETIME=28800
# How long an employee edit stays locked when the editor goes idle (30 min).
LOCK_TIMEOUT=1800

# --- Image handling ---
# Uploaded photos are downscaled to fit this many pixels on the long edge...
IMAGE_MAX_DIM=1000
# ...and re-encoded at this JPEG/WebP quality (1-100).
IMAGE_QUALITY=82
